    <form id="contactForm">
      <div class="form-row">
        <div>
          <label for="fName">الاسم</label>
          <input type="text" id="fName" required>
        </div>
        <div>
          <label for="fClinic">اسم العيادة</label>
          <input type="text" id="fClinic" required>
