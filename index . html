<footer>
  <div class="wrap footer-inner">
    <span>&copy; 2026 Dentawy &mdash; جميع الحقوق محفوظة</span>
    <a href="#" id="adminLink">دخول الفريق</a>
  </div>
</footer>

</div>

<!-- ============ ADMIN VIEW ============ -->
<div id="admin-view">
  <div class="admin-bar">
    <div class="wrap">
      <div class="wordmark" style="font-size:1.1rem;">DENTAWY <span class="tag" style="opacity:0.7;">لوحة التحكم</span></div>
      <a href="#" class="back-link" id="backToSite">الرجوع للموقع &larr;</a>
    </div>
  </div>

  <div id="gateBox" class="gate">
    <h2>دخول لوحة التحكم</h2>
    <p>الرسائل دي بتوصل من نموذج التواصل في الموقع. اكتب كلمة المرور للمتابعة.</p>
    <input type="password" id="gatePass" placeholder="كلمة المرور">
    <p class="err-msg" id="gateErr"></p>
    <button class="btn btn-primary" style="width:100%;" id="gateSubmit">دخول</button>
  </div>

  <div id="inboxBox" class="inbox" style="display:none;">
    <div class="inbox-head">
      <h2>رسائل العملاء</h2>
      <button class="refresh-btn" id="refreshBtn">تحديث</button>
    </div>
    <div id="msgList"></div>
  </div>
</div>

<script>
  // ---- Mobile nav ----
  const burgerBtn = document.getElementById('burgerBtn');
  const navLinks = document.getElementById('navLinks');
  burgerBtn.addEventListener('click', () => {
    const isOpen = navLinks.classList.toggle('open');
    burgerBtn.setAttribute('aria-expanded', isOpen);
  });
  navLinks.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    navLinks.classList.remove('open');
    burgerBtn.setAttribute('aria-expanded', 'false');
  }));

  // ---- Contact form -> shared persistent storage ----
  const MESSAGES_KEY = 'dentawy:contact-messages';
  const ADMIN_PASSCODE = 'dentawy2026';

  const contactForm = document.getElementById('contactForm');
  const formMsg = document.getElementById('formMsg');

  contactForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const entry = {
      name: document.getElementById('fName').value.trim(),
      clinic: document.getElementById('fClinic').value.trim(),
      phone: document.getElementById('fPhone').value.trim(),
      message: document.getElementById('fMsg').value.trim(),
      date: new Date().toISOString()
    };

    formMsg.textContent = 'جاري الإرسال...';
    formMsg.className = 'form-msg';

    try {
      let list = [];
      try {
        const existing = await window.storage.get(MESSAGES_KEY, true);
        if (existing && existing.value) list = JSON.parse(existing.value);
      } catch (readErr) {
        list = [];
      }
      list.unshift(entry);
      const result = await window.storage.set(MESSAGES_KEY, JSON.stringify(list), true);
      if (!result) throw new Error('save failed');
      formMsg.textContent = 'تم استلام رسالتك، هنتواصل معاك قريب.';
      formMsg.className = 'form-msg ok';
      contactForm.reset();
    } catch (err) {
      console.error('Storage error:', err);
      formMsg.textContent = 'حصل خطأ أثناء الإرسال، حاول تاني.';
      formMsg.className = 'form-msg err';
    }
  });

  // ---- Admin view routing ----
  const siteView = document.getElementById('site-view');
  const adminView = document.getElementById('admin-view');
  const adminLink = document.getElementById('adminLink');
  const backToSite = document.getElementById('backToSite');
  const gateBox = document.getElementById('gateBox');
  const inboxBox = document.getElementById('inboxBox');
  const gatePass = document.getElementById('gatePass');
  const gateErr = document.getElementById('gateErr');
  const gateSubmit = document.getElementById('gateSubmit');
  const msgList = document.getElementById('msgList');
  const refreshBtn = document.getElementById('refreshBtn');

  function showAdmin() {
    siteView.style.display = 'none';
    adminView.style.display = 'block';
    gateBox.style.display = 'block';
    inboxBox.style.display = 'none';
    gatePass.value = '';
    gateErr.textContent = '';
  }
  function showSite() {
    adminView.style.display = 'none';
    siteView.style.display = 'block';
  }

  adminLink.addEventListener('click', (e) => { e.preventDefault(); showAdmin(); });
  backToSite.addEventListener('click', (e) => { e.preventDefault(); showSite(); });

  gateSubmit.addEventListener('click', () => {
    if (gatePass.value === ADMIN_PASSCODE) {
      gateBox.style.display = 'none';
      inboxBox.style.display = 'block';
      loadMessages();
    } else {
      gateErr.textContent = 'كلمة المرور غير صحيحة';
    }
  });
  gatePass.addEventListener('keydown', (e) => { if (e.key === 'Enter') gateSubmit.click(); });

  function formatDate(iso) {
    try {
      const d = new Date(iso);
      return d.toLocaleString('ar-EG', { dateStyle: 'medium', timeStyle: 'short' });
    } catch { return iso; }
  }

  async function loadMessages() {
    msgList.innerHTML = '<p style="color:#4A554F;">جاري التحميل...</p>';
    try {
      let list = [];
      try {
        const result = await window.storage.get(MESSAGES_KEY, true);
        if (result && result.value) list = JSON.parse(result.value);
      } catch (readErr) {
        list = [];
      }

      if (!list.length) {
        msgList.innerHTML = `
          <div class="empty-state">
            <h3>لسه مفيش رسائل</h3>
            <p>لما حد يبعت طلب من نموذج التواصل في الموقع، هيظهر هنا.</p>
          </div>`;
        return;
      }

      msgList.innerHTML = list.map(m => `
        <div class="msg-card">
          <div class="msg-card-top">
            <h3>${escapeHtml(m.name || 'بدون اسم')}</h3>
            <time>${formatDate(m.date)}</time>
          </div>
          <div class="msg-meta">
            ${escapeHtml(m.clinic || '')} &middot; <span class="mono">${escapeHtml(m.phone || '')}</span>
          </div>
          <p class="body">${escapeHtml(m.message || '')}</p>
        </div>
      `).join('');
    } catch (err) {
      console.error(err);
      msgList.innerHTML = '<p style="color:var(--danger);">حصل خطأ في تحميل الرسائل.</p>';
    }
  }

  function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  refreshBtn.addEventListener('click', loadMessages);
</script>
</body>
</html>
